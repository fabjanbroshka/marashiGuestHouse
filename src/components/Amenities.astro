---
const amenities = [
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><path d="M5 12.55a11 11 0 0 1 14.08 0"/><path d="M1.42 9a16 16 0 0 1 21.16 0"/><path d="M8.53 16.11a6 6 0 0 1 6.95 0"/><circle cx="12" cy="20" r="1" fill="currentColor"/></svg>`,
    title: 'Free Wi-Fi',
    desc: 'High-speed internet throughout the guesthouse',
    img: '/image1.jpg',
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>`,
    title: 'Home Dining',
    desc: 'Traditional Albanian breakfast & dinner daily',
    img: '/image2.jpg',
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><rect x="1" y="3" width="15" height="13" rx="2"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>`,
    title: 'Free Parking',
    desc: 'Secure on-site parking for all guests',
    img: '/photo1.jpg',
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><path d="M3 17l9-13 9 13"/><line x1="3" y1="17" x2="21" y2="17"/><line x1="8" y1="17" x2="8" y2="21"/><line x1="16" y1="17" x2="16" y2="21"/></svg>`,
    title: 'Mountain Tours',
    desc: 'Guided hikes through the Albanian Alps',
    img: '/photo2.jpg',
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78L12 21.23l8.84-8.84a5.5 5.5 0 0 0 0-7.78z"/></svg>`,
    title: 'Warm Hospitality',
    desc: 'Family warmth and 24/7 attentive service',
    img: '/photo3.jpg',
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><path d="M18 8h1a4 4 0 0 1 0 8h-1"/><path d="M2 8h16v9a4 4 0 0 1-4 4H6a4 4 0 0 1-4-4V8z"/><line x1="6" y1="1" x2="6" y2="4"/><line x1="10" y1="1" x2="10" y2="4"/><line x1="14" y1="1" x2="14" y2="4"/></svg>`,
    title: 'Raki & Coffee Bar',
    desc: 'Traditional Albanian drinks & local spirits',
    img: '/photo4.jpg',
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>`,
    title: 'Airport Transfer',
    desc: 'Pickup & drop-off service on request',
    img: '/image1.jpg',
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>`,
    title: 'Local Experiences',
    desc: 'Cultural tours, fishing, and village visits',
    img: '/image2.jpg',
  },
];
---

<section class="amenities section" id="amenities">
  <div class="container">
    <div class="amen-header">
      <p class="section-label">What We Offer</p>
      <h2 class="section-title">Guesthouse Amenities</h2>
      <p class="section-subtitle">
        Everything you need for an authentic and comfortable stay in the heart of Albania.
      </p>
    </div>

    <div class="amen-grid">
      {amenities.map(a => (
        <div class="amen-card">
          <div class="amen-image">
            <img src={a.img} alt={a.title} loading="lazy" />
          </div>
          <div class="amen-icon" set:html={a.icon} />
          <div class="amen-body">
            <h3 class="amen-title">{a.title}</h3>
            <p class="amen-desc">{a.desc}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .amenities {
    background: var(--white);
  }

  .amen-header {
    text-align: left;
    margin-bottom: 3.5rem;
  }

  .amen-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
  }

  .amen-card {
    background: var(--light);
    border-radius: 14px;
    overflow: hidden;
    text-align: center;
    border: 1px solid transparent;
  }

  .amen-image {
    height: 140px;
    overflow: hidden;
  }

  .amen-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.5s ease;
  }

  .amen-card:hover .amen-image img {
    transform: scale(1.05);
  }

.amen-icon {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: var(--gold);
    color: var(--white);
    display: flex;
    align-items: center;
    justify-content: center;
    margin: -28px auto 0;
    position: relative;
    z-index: 1;
    transition: all var(--transition);
    border: 3px solid var(--white);
  }

  .amen-body {
    padding: 1rem 1.25rem 1.5rem;
  }

  .amen-title {
    font-family: var(--font-heading);
    font-size: 1.0625rem;
    font-weight: 600;
    color: var(--dark);
    margin-bottom: 0.5rem;
  }

  .amen-desc {
    font-size: 0.875rem;
    color: var(--muted);
    line-height: 1.6;
  }

  @media (max-width: 1024px) {
    .amen-grid { grid-template-columns: repeat(3, 1fr); }
  }

  @media (max-width: 768px) {
    .amen-header {
      flex-direction: column;
      align-items: flex-start;
      gap: 1rem;
    }
    .amen-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 480px) {
    .amen-grid { grid-template-columns: 1fr; }
  }
</style>
