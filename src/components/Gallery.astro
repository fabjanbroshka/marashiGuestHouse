---
const photos = [
  { label: 'Albanian Alps',      span: 'tall',   src: '/image1.jpg',  alt: 'Albanian Alps landscape' },
  { label: 'Guest Room',         span: 'normal', src: '/photo1.jpg',  alt: 'Cozy guest room' },
  { label: 'Traditional Cuisine',span: 'normal', src: '/photo2.jpg',  alt: 'Traditional Albanian cuisine' },
  { label: 'Mountain View',      span: 'wide',   src: '/image2.jpg',  alt: 'Panoramic mountain view' },
  { label: 'Balcony Sunset',     span: 'normal', src: '/photo3.jpg',  alt: 'Sunset from the balcony' },
  { label: 'Stone Terrace',      span: 'tall',   src: '/photo4.jpg',  alt: 'Stone terrace and surroundings' },
  { label: 'Local Village',      span: 'normal', src: '/photo1.jpg',  alt: 'Local Albanian village' },
];
---

<section class="gallery section" id="gallery">
  <div class="container">
    <div class="gallery-header">
      <div class="gallery-header-left">
        <p class="section-label">Photography</p>
        <h2 class="section-title">The Marashi Experience</h2>
        <p class="section-subtitle">
          A glimpse into the landscapes, spaces, and moments that make Marashi Guesthouse
          a truly unforgettable destination.
        </p>
      </div>
      <div class="gallery-socials">
        <a href="https://instagram.com" target="_blank" rel="noopener" aria-label="Instagram" class="social-link">
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="5"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/></svg>
        </a>
        <a href="https://facebook.com" target="_blank" rel="noopener" aria-label="Facebook" class="social-link">
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
        </a>
        <a href="https://tiktok.com" target="_blank" rel="noopener" aria-label="TikTok" class="social-link">
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><path d="M9 12a4 4 0 1 0 4 4V4a5 5 0 0 0 5 5"/></svg>
        </a>
        <a href="https://youtube.com" target="_blank" rel="noopener" aria-label="YouTube" class="social-link">
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><path d="M22.54 6.42a2.78 2.78 0 0 0-1.95-1.96C18.88 4 12 4 12 4s-6.88 0-8.59.46A2.78 2.78 0 0 0 1.46 6.42 29 29 0 0 0 1 12a29 29 0 0 0 .46 5.58 2.78 2.78 0 0 0 1.95 1.95C5.12 20 12 20 12 20s6.88 0 8.59-.47a2.78 2.78 0 0 0 1.95-1.95A29 29 0 0 0 23 12a29 29 0 0 0-.46-5.58z"/><polygon points="9.75 15.02 15.5 12 9.75 8.98 9.75 15.02" fill="currentColor" stroke="none"/></svg>
        </a>
      </div>
    </div>
  </div>

  <div class="gallery-grid">
    {photos.map(photo => (
      <div class={`gallery-item span-${photo.span}`}>
        <img src={photo.src} alt={photo.alt} loading="lazy" />
        <div class="gallery-overlay">
          <span class="gallery-label">{photo.label}</span>
        </div>
      </div>
    ))}
  </div>
</section>

<style>
  .gallery {
    background: var(--dark);
    padding-bottom: 0;
  }

  .gallery-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 2rem;
    margin-bottom: 3rem;
  }

  .gallery-header .section-title,
  .gallery-header .section-label {
    color: var(--white);
  }

  .gallery-header .section-subtitle {
    color: rgba(255,255,255,0.55);
    margin-top: 0.5rem;
  }

  .gallery-socials {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    align-items: center;
  }

  .social-link {
    color: rgba(255,255,255,0.55);
    transition: color var(--transition);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .social-link:hover {
    color: var(--white);
  }

  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    grid-auto-rows: 220px;
    gap: 4px;
  }

  .gallery-item {
    position: relative;
    overflow: hidden;
    cursor: pointer;
    background: #111;
  }

  .gallery-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
    display: block;
  }

  .gallery-item:hover img {
    transform: scale(1.06);
  }

  .span-tall { grid-row: span 2; }
  .span-wide { grid-column: span 2; }
  .span-normal { grid-row: span 1; grid-column: span 1; }

  .gallery-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.65) 0%, transparent 60%);
    display: flex;
    align-items: flex-end;
    padding: 1.25rem;
    opacity: 0;
    transition: opacity var(--transition);
  }

  .gallery-item:hover .gallery-overlay {
    opacity: 1;
  }

  .gallery-label {
    font-family: var(--font-heading);
    font-style: italic;
    font-size: 1rem;
    color: var(--white);
  }

  @media (max-width: 900px) {
    .gallery-header {
      flex-direction: column;
      align-items: flex-start;
      gap: 1.5rem;
    }

    .gallery-socials {
      flex-direction: row;
    }
    .gallery-grid {
      grid-template-columns: repeat(2, 1fr);
    }
    .span-wide { grid-column: span 2; }
  }

  @media (max-width: 560px) {
    .gallery-grid {
      grid-template-columns: 1fr 1fr;
      grid-auto-rows: 160px;
    }
    .span-tall { grid-row: span 1; }
    .span-wide { grid-column: span 2; }
  }
</style>
