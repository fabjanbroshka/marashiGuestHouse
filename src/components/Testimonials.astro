---
const reviews = [
  {
    name: 'Sophie Laurent',
    country: 'France',
    flag: '🇫🇷',
    rating: 5,
    text: 'One of the most memorable stays of my travels. The family made us feel like we belonged there. The food was extraordinary — every meal felt like a celebration of Albanian culture.',
    stay: 'Stayed in Deluxe Room, September 2024',
  },
  {
    name: 'Marco Bianchi',
    country: 'Italy',
    flag: '🇮🇹',
    rating: 5,
    text: 'Hidden gem of the Balkans! The mountain views from the balcony were worth every kilometer of travel. The guided hike arranged by the family was the highlight of our trip.',
    stay: 'Stayed in Family Suite, July 2024',
  },
  {
    name: 'Emma Schmidt',
    country: 'Germany',
    flag: '🇩🇪',
    rating: 5,
    text: 'The warmth and authenticity here cannot be found in any hotel. We arrived as strangers and left as friends of the Marashi family. Already planning our return next summer.',
    stay: 'Stayed in Standard Room, May 2024',
  },
];

function stars(n: number) {
  return '★'.repeat(n) + '☆'.repeat(5 - n);
}
---

<section class="testimonials section" id="testimonials">
  <div class="container">
    <div class="test-header">
      <div class="test-header-left">
        <p class="section-label">Guest Reviews</p>
        <h2 class="section-title">What Our Guests Say</h2>
        <p class="section-subtitle">
          We are proud of the memories we help create. Here is what our guests share.
        </p>
      </div>
      <div class="test-socials">
        <a href="https://instagram.com" target="_blank" rel="noopener" aria-label="Instagram" class="social-link">
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="5"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/></svg>
        </a>
        <a href="https://facebook.com" target="_blank" rel="noopener" aria-label="Facebook" class="social-link">
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
        </a>
        <a href="https://tiktok.com" target="_blank" rel="noopener" aria-label="TikTok" class="social-link">
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><path d="M9 12a4 4 0 1 0 4 4V4a5 5 0 0 0 5 5"/></svg>
        </a>
        <a href="https://youtube.com" target="_blank" rel="noopener" aria-label="YouTube" class="social-link">
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><path d="M22.54 6.42a2.78 2.78 0 0 0-1.95-1.96C18.88 4 12 4 12 4s-6.88 0-8.59.46A2.78 2.78 0 0 0 1.46 6.42 29 29 0 0 0 1 12a29 29 0 0 0 .46 5.58 2.78 2.78 0 0 0 1.95 1.95C5.12 20 12 20 12 20s6.88 0 8.59-.47a2.78 2.78 0 0 0 1.95-1.95A29 29 0 0 0 23 12a29 29 0 0 0-.46-5.58z"/><polygon points="9.75 15.02 15.5 12 9.75 8.98 9.75 15.02" fill="currentColor" stroke="none"/></svg>
        </a>
      </div>
    </div>

    <div class="reviews-grid">
      {reviews.map(review => (
        <div class="review-card">
          <blockquote class="review-text">"{review.text}"</blockquote>
          <div class="review-author">
            <div class="author-avatar">
              {review.name.split(' ').map(n => n[0]).join('')}
            </div>
            <div>
              <div class="author-name">{review.flag} {review.name}</div>
              <div class="author-stay">{review.stay}</div>
            </div>
          </div>
        </div>
      ))}
    </div>

  </div>
</section>

<style>
  .testimonials {
    background: var(--light);
  }

  .test-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 2rem;
    margin-bottom: 3.5rem;
  }

  .test-socials {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    align-items: center;
  }

  .social-link {
    color: var(--muted);
    transition: color var(--transition);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .social-link:hover {
    color: var(--dark);
  }

  .reviews-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.75rem;
    margin-bottom: 3rem;
  }

  .review-card {
    background: var(--white);
    border-radius: 16px;
    padding: 2rem;
    box-shadow: var(--shadow-sm);
    transition: all var(--transition);
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .review-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-md);
  }

.review-text {
    font-family: var(--font-body);
    font-style: normal;
    font-size: 1.0rem;
    color: var(--text);
    line-height: 1.75;
    flex: 1;
  }

  .review-author {
    display: flex;
    align-items: center;
    gap: 0.875rem;
    padding-top: 1rem;
    border-top: 1px solid var(--border);
  }

  .author-avatar {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--primary), var(--primary-dark));
    color: var(--white);
    font-size: 0.875rem;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .author-name {
    font-weight: 600;
    font-size: 0.9375rem;
    color: var(--dark);
    margin-bottom: 0.2rem;
  }

  .author-stay {
    font-size: 0.8125rem;
    color: var(--muted);
  }

  /* Overall rating */
  .overall-rating {
    display: flex;
    align-items: center;
    gap: 2rem;
    background: var(--dark);
    color: var(--white);
    padding: 2rem 2.5rem;
    border-radius: 16px;
    max-width: 680px;
    margin: 0 auto;
  }

  .rating-score {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-shrink: 0;
  }

  .score-num {
    font-family: var(--font-heading);
    font-size: 3.5rem;
    font-weight: 700;
    color: var(--gold);
    line-height: 1;
  }

  .score-stars {
    color: var(--gold);
    font-size: 1.125rem;
    margin-bottom: 0.2rem;
  }

  .score-label {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: rgba(255,255,255,0.6);
  }

  .rating-sep {
    width: 1px;
    height: 50px;
    background: rgba(255,255,255,0.15);
    flex-shrink: 0;
  }

  .rating-text {
    font-size: 0.9375rem;
    color: rgba(255,255,255,0.7);
    line-height: 1.65;
  }

  @media (max-width: 900px) {
    .test-header {
      flex-direction: column;
      align-items: flex-start;
      gap: 1.5rem;
    }

    .test-socials {
      flex-direction: row;
    }
    .reviews-grid { grid-template-columns: 1fr 1fr; }
  }

  @media (max-width: 600px) {
    .reviews-grid { grid-template-columns: 1fr; }
  }
</style>
