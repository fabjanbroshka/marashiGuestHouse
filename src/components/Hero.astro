---
---

<section class="hero" id="home">
  <div class="hero-bg">
    <img src="/image1.jpg" alt="Albanian mountains landscape" class="hero-img" />
  </div>
  <div class="hero-overlay"></div>

  <div class="hero-content">
<h1 class="hero-title">
      Welcome to Marashi Guesthouse - Your Cosy Kiwi Getaway
    </h1>
    <p class="hero-subtitle">
      Experience the warmth of authentic Albanian hospitality.<br />
      Nestled among the majestic Albanian Alps.
    </p>

<div class="hero-actions">
      <a href="#rooms" class="btn btn-primary">Explore Rooms</a>
      <a href="#about" class="btn btn-outline">Our Story</a>
    </div>
  </div>

  <div class="hero-scroll">
    <span class="scroll-text">Scroll down</span>
    <div class="scroll-line"></div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  /* Background */
  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

.hero-overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: linear-gradient(
      to right,
      rgba(10, 10, 10, 0.72) 0%,
      rgba(10, 10, 10, 0.45) 50%,
      rgba(10, 10, 10, 0.2) 100%
    );
  }

  /* Content */
  .hero-content {
    position: relative;
    z-index: 2;
    padding-top: 6rem;
    padding-bottom: 6rem;
    max-width: 620px;
    margin: 0;
    padding-left: clamp(1.5rem, 6vw, 6rem);
    padding-right: 1.5rem;
  }

.hero-title {
    font-family: var(--font-heading);
    font-size: clamp(1.8rem, 4.5vw, 3.5rem);
    font-weight: 700;
    color: var(--white);
    line-height: 1.0;
    margin-bottom: 1.5rem;
    letter-spacing: -0.02em;
  }

.hero-subtitle {
    font-size: clamp(1rem, 2vw, 1.2rem);
    color: rgba(255,255,255,0.8);
    line-height: 1.65;
    margin-bottom: 2.5rem;
    max-width: 480px;
  }

/* Actions */
  .hero-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  /* Scroll indicator */
  .hero-scroll {
    position: absolute;
    bottom: 2.5rem;
    right: 3rem;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    animation: fadeIn 2s ease 1s both;
  }

  .scroll-text {
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.5);
    writing-mode: vertical-rl;
  }

  .scroll-line {
    width: 1px;
    height: 60px;
    background: linear-gradient(to bottom, rgba(255,255,255,0.4), transparent);
    animation: scrollLine 1.8s ease-in-out infinite;
  }

  @keyframes scrollLine {
    0%, 100% { transform: scaleY(1); transform-origin: top; opacity: 1; }
    50% { transform: scaleY(0.3); transform-origin: top; opacity: 0.3; }
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @media (max-width: 768px) {
    .hero-scroll { display: none; }

    .hero-content {
      max-width: 100%;
      padding-left: 1.5rem;
      padding-right: 1.5rem;
    }

    .hero-actions {
      flex-direction: column;
    }

    .hero-actions .btn {
      width: 100%;
      justify-content: center;
    }
  }
</style>
